    "@tiptap/starter-kit": "^2.6.6",
    "framer-motion": "^11.5.4",
    "next": "^14.2.35",
    "next-intl": "^3.19.4",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-hook-form": "^7.53.0",
    "react-simple-maps": "^3.0.0",
    "resend": "^4.0.0",
