{
  "name": "petra-io-website",
  "version": "0.1.0",
  "private": true,
  "description": "Public website for the International Office of Petra Christian University (PETRA)",
  "scripts": {
    "dev": "cross-env NODE_OPTIONS=--require=./scripts/patch-readlink.cjs next dev",
    "build": "cross-env NODE_OPTIONS=--require=./scripts/patch-readlink.cjs next build",
    "start": "next start",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "db:seed": "cross-env NODE_OPTIONS=--require=./scripts/patch-readlink.cjs tsx supabase/seed.ts",
    "db:seed:pages": "cross-env NODE_OPTIONS=--require=./scripts/patch-readlink.cjs tsx supabase/seed-pages.ts",
    "db:seed:icop": "cross-env NODE_OPTIONS=--require=./scripts/patch-readlink.cjs tsx supabase/seed-icop-page.ts",
    "db:seed:spectrum": "cross-env NODE_OPTIONS=--require=./scripts/patch-readlink.cjs tsx supabase/seed-spectrum-page.ts",
    "db:seed:accreditation": "cross-env NODE_OPTIONS=--require=./scripts/patch-readlink.cjs tsx supabase/seed-accreditation-page.ts",
    "db:seed:accreditation-data": "cross-env NODE_OPTIONS=--require=./scripts/patch-readlink.cjs tsx supabase/seed-accreditation-data.ts",
    "db:seed:domestic-logos": "cross-env NODE_OPTIONS=--require=./scripts/patch-readlink.cjs tsx supabase/seed-domestic-partner-logos.ts"
  },
  "dependencies": {
