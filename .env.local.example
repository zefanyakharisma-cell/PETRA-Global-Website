# Copy to .env.local and fill in. Never commit real secrets.

# --- Supabase (shared project nvwwkehglccokobxwelp) ---
# PETRA tables live ONLY in the dedicated `petra_io` Postgres schema, never `public`.
NEXT_PUBLIC_SUPABASE_URL=https://nvwwkehglccokobxwelp.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
# Server-only. Used by seed script / privileged server actions. Never expose to the client.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# --- Resend (inquiry notifications) ---
RESEND_API_KEY=your-resend-key
# From address for notification emails (must be a verified Resend domain).
RESEND_FROM_EMAIL="PETRA International Office <io@petra.ac.id>"

# --- Site ---
NEXT_PUBLIC_SITE_URL=http://localhost:3000
# Where the student inquiry form's "Apply via Admissions" links out to.
NEXT_PUBLIC_ADMISSIONS_URL=https://admission.petra.ac.id
